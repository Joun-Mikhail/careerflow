# Normalize line endings to LF in the repository for cross-platform consistency.
* text=auto eol=lf

# Scripts and container files must always use LF to run on Linux.
*.sh        text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
