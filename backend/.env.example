# ---------------------------------------------------------------------------
# CareerFlow backend configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# Runtime profile: "local" | "production" | "test"
CAREERFLOW_ENV=local
DEBUG=true

# Database (SQLAlchemy URL). Default points at the Compose Postgres service.
DATABASE_URL=postgresql+psycopg://careerflow:careerflow@db:5432/careerflow

# JWT — generate a strong secret for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Password hashing cost (bcrypt rounds)
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed SPA origins.
# The Capacitor entries let the iOS/Android mobile wrapper talk to a local
# backend; remove them if you don't ship a mobile build.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost,http://localhost,capacitor://localhost,ionic://localhost

# Error reporting (optional). Leave blank to disable Sentry.
SENTRY_DSN=

# AI CV tailoring (optional). With no key, a deterministic stub is used so the
# feature works in dev/tests at zero cost. Set a real key in production.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Job source — Adzuna (https://developer.adzuna.com, free tier). With no
# credentials a mock provider returns sample postings so search still works.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# File uploads
UPLOAD_DIR=var/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# Object storage for the document vault (S3-compatible, e.g. Cloudflare R2).
# Leave blank to store uploads on local disk (fine for dev; ephemeral on
# managed hosts). When all four are set, uploads go to the bucket instead.
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# API metadata
API_V1_PREFIX=/api/v1
PROJECT_NAME=CareerFlow
