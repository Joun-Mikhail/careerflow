# ---------------------------------------------------------------------------
# CareerFlow backend configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# Runtime profile: "local" | "production" | "test"
CAREERFLOW_ENV=local
DEBUG=true

# Database (SQLAlchemy URL). Default points at the Compose Postgres service.
DATABASE_URL=postgresql+psycopg://careerflow:careerflow@db:5432/careerflow

# JWT — generate a strong secret for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Password hashing cost (bcrypt rounds)
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed SPA origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Error reporting (optional). Leave blank to disable Sentry.
SENTRY_DSN=

# File uploads
UPLOAD_DIR=var/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# API metadata
API_V1_PREFIX=/api/v1
PROJECT_NAME=CareerFlow
