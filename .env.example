# Root environment for docker-compose. Copy to `.env` to override defaults.
# These defaults are for local development only — never use them in production.

# Postgres
POSTGRES_USER=careerflow
POSTGRES_PASSWORD=careerflow
POSTGRES_DB=careerflow

# Backend
CAREERFLOW_ENV=local
DEBUG=true
# Generate a strong value for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me-32-bytes-minimum-secret
CORS_ORIGINS=http://localhost:5173
# Seed a demo account (demo@careerflow.app / DemoPass123!) on first start.
SEED_DEMO_DATA=true

# Frontend
FRONTEND_PORT=5173
