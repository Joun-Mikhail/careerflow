{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/install", "destination": "/install/index.html" },
    { "source": "/install/", "destination": "/install/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
