# Base URL for the CareerFlow API. In local dev the Vite proxy forwards /api to
# the backend, so the default relative path works without changes.
#
# For mobile builds (Capacitor), this must be an absolute https:// URL — the
# bundled WebView cannot proxy through Vite. Example:
#   VITE_API_BASE_URL=https://careerflow-api-production.up.railway.app/api/v1
VITE_API_BASE_URL=/api/v1

# Optional Sentry browser error reporting. Leave blank to disable.
VITE_SENTRY_DSN=
